# ============================
# .env.example
# 复制为 .env 并填入真实值
# ============================

# LLM API Keys —— 主力
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# LLM API Keys —— Anthropic（子代理使用，通过灵算等中转服务）
# ANTHROPIC_AUTH_TOKEN: 部分中转服务使用此字段替代 ANTHROPIC_API_KEY
# ANTHROPIC_BASE_URL: 中转服务地址，如 https://lingsuan.top
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# LLM 提供商 (deepseek / openai / anthropic)
LLM_PROVIDER=deepseek

# 运行模式
DEBUG=true
LOG_LEVEL=DEBUG
