# LLM API Keys —— 留空即可，真实密钥通过凭据管理器读取
# 凭据管理器服务名: litchi-head
# 设置工具: python scripts/store-api-keys.py
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://lingsuan.top

# LLM 提供商 (deepseek / openai / anthropic)
LLM_PROVIDER=deepseek

# 运行模式
DEBUG=true
LOG_LEVEL=DEBUG
