# ============================
# .env.example
# 复制为 .env 并填入真实值
# ============================

# LLM API Keys —— 主力（Python 默认 + Claude Code 主会话共用）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# LLM API Keys —— 灵算中转（仅 Python 代码 provider=anthropic 时使用）
# 勿把 ANTHROPIC_BASE_URL 写入 Windows 全局环境变量，否则会破坏 Claude Code DeepSeek 主会话
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://lingsuan.top

# LLM 提供商 (deepseek / openai / anthropic)
LLM_PROVIDER=deepseek

# 运行模式
DEBUG=true
LOG_LEVEL=DEBUG
