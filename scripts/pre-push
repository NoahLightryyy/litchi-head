#!/bin/bash
# pre-push — Git pre-push hook: 推送前本地 CI 检查
#
# 安装: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# 跳过: git push --no-verify（仅限修 CI 本身或紧急情况）
#
# 如果本项目的 CLAUDE.md 设置了 hooksPath，则可能自动安装。
# 参见: docs/01-guides/ci/HANDBOOK.md §3

echo "╔══════════════════════════════════════════════╗"
echo "║  🔄 Pre-push: 本地 CI 预检                   ║"
echo "║  检测失败 → 阻止推送, 修复后再试              ║"
echo "║  跳过: git push --no-verify                  ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# 保存当前 stash 状态（防止未暂存文件干扰检测）
STASHED=false
if ! git diff --quiet || ! git diff --cached --quiet; then
    git stash push --include-untracked --message "pre-push-auto-stash" 2>/dev/null
    STASHED=true
fi

FAILED=0

echo "--- [1/3] Ruff (代码风格) ---"
ruff check .
if [ $? -ne 0 ]; then
    echo "❌ Ruff 检查失败。运行 ruff check . --fix 自动修复"
    FAILED=1
fi
echo ""

echo "--- [2/3] Pyright (类型检查) ---"
pyright src/
if [ $? -ne 0 ]; then
    echo "❌ Pyright 类型检查失败"
    FAILED=1
fi
echo ""

echo "--- [3/3] Pytest (测试) ---"
pytest -v --tb=short
if [ $? -ne 0 ]; then
    echo "❌ Pytest 测试失败"
    FAILED=1
fi
echo ""

# 恢复 stash
if [ "$STASHED" = true ]; then
    git stash pop 2>/dev/null
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════╗"
    echo "║  ❌ 推送被阻止：本地 CI 预检未通过           ║"
    echo "║  修复后再推送，或用 --no-verify 跳过         ║"
    echo "║  跳过仅限修 CI 本身或紧急情况                ║"
    echo "║  详情: docs/01-guides/ci/WORKFLOW.md        ║"
    echo "╚══════════════════════════════════════════════╝"
    exit 1
fi

echo "╔══════════════════════════════════════════════╗"
echo "║  ✅ 本地 CI 预检通过，推送继续                ║"
echo "║  等 GitHub Actions 跑完确认全绿               ║"
echo "╚══════════════════════════════════════════════╝"
exit 0
